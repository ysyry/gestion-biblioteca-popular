# ── Conexión a Koha (DigiBePé) ─────────────────────────────────────────────
# URL base de la INTRANET (staff), sin barra final.
KOHA_BASE_URL=http://3169.bepe.ar:8080
# Credenciales SOLO para scripts/probe_koha.py (la app usa las de cada bibliotecaria).
KOHA_USER=
KOHA_PASSWORD=

# ── IDs de los reportes SQL guardados en la intranet ───────────────────────
# Completar después de crear cada reporte (ver backend/sql/). Dejar vacío si aún no existe.
REPORT_MEMBER_SEARCH_ID=
REPORT_MEMBER_LOANS_ID=
REPORT_LOANS_ACTIVE_ID=
REPORT_LOANS_OVERDUE_ID=
REPORT_MEMBER_PROFILE_ID=
REPORT_MEMBER_ACCOUNT_ID=
REPORT_MEMBER_HISTORY_ID=

# ── Auth de la app ─────────────────────────────────────────────────────────
# Las bibliotecarias entran con su usuario/contraseña de Koha. Esta clave solo
# firma el token de sesión que emite la app. Cambiala por algo aleatorio largo.
APP_SECRET_KEY=cambiar-esto-por-un-secreto-largo-y-aleatorio
APP_TOKEN_EXPIRE_MINUTES=480

# ── CORS (orígenes del frontend permitidos, separados por coma) ────────────
CORS_ORIGINS=http://localhost:5173

# ── Envío de mails (SMTP) ──────────────────────────────────────────────────
# Ejemplo Gmail: host=smtp.gmail.com puerto=587, user=cuenta@gmail.com,
# password = "contraseña de aplicación" (no la normal), from=cuenta@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Biblioteca Popular Osvaldo Bayer
SMTP_USE_TLS=true
# SEGURIDAD: en true NO envía de verdad (simula). Poné false recién cuando quieras enviar.
MAIL_DRY_RUN=true
